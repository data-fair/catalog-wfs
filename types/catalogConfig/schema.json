{
  "$id": "https://github.com/data-fair/catalog-wfs/catalog-config",
  "x-exports": [
    "types",
    "validate",
    "schema"
  ],
  "title": "WFSConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "url"
  ],
  "properties": {
    "url": {
      "type": "string",
      "title": "WFS URL",
      "description": "URL du service WFS (ex: https://geoserver.example.com/wfs)",
      "x-i18n-description": {
        "fr": "URL du service WFS (ex: https://geoserver.example.com/wfs)"
      },
      "pattern": "^https?://.*[^/]$",
      "errorMessage": "The URL must start with http:// or https:// and must not end with `/`.",
      "x-i18n-errorMessage": {
        "fr": "L'URL doit commencer par http:// ou https:// et ne pas se terminer par `/`."
      },
      "examples": ["https://geoserver.example.com/wfs"]
    },
    "version": {
      "type": "string",
      "title": "Version WFS",
      "description": "Version du service WFS à utiliser",
      "x-i18n-description": {
        "fr": "Version du service WFS à utiliser"
      },
      "default": "2.0.0",
      "enum": [
        "1.0.0",
        "1.1.0",
        "2.0.0"
      ]
    }
  }
}
